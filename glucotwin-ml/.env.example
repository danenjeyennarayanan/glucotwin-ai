# ── GlucoTwin AI ML Service — Environment Variables ────────────────────────

PORT=5001
DEBUG=false

# Origins allowed to call this service directly (from browser)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Paths to model artifacts
MODEL_PATH=model/diabetes_model.pkl
EXPLAINER_PATH=model/shap_explainer.pkl

# Path to training dataset (only needed if model not pre-trained)
DATASET_PATH=diabetes_prediction_dataset.csv
