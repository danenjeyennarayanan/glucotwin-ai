# ── GlucoTwin AI Frontend Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in values before running

# Spring Boot backend base URL (no trailing slash)
REACT_APP_API_BASE=http://localhost:8080

# Flask ML service base URL (direct calls only needed if bypassing backend)
REACT_APP_ML_BASE=http://localhost:5001

# App name shown in browser tab
REACT_APP_NAME=GlucoTwin AI
