# ── GlucoTwin AI Backend — Environment Variables ───────────────────────────
# Copy to .env and fill in values. NEVER commit .env to version control.

# Database
DB_URL=jdbc:mysql://localhost:3306/glucotwin_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=glucotwin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (must be at least 32 characters)
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_MIN_32_CHARS_xxxxxxxxxxxxxxxx
JWT_EXPIRATION=86400000

# ML Service URL
ML_SERVICE_URL=http://localhost:5001

# CORS — comma-separated list of allowed frontend origins (NO trailing slash)
CORS_ORIGINS=http://localhost:3000

# Server port
PORT=8080

# ── Anthropic AI Chatbot ────────────────────────────────────────────────────
# Optional. Get your key at https://console.anthropic.com/
# If not set, the chatbot uses built-in fallback responses (suitable for demo).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email (optional — set EMAIL_ENABLED=true to send real emails)
EMAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
